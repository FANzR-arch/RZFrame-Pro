{
  "name": "rzframe-workstation-pro",
  "productName": "RZFrame Workstation",
  "version": "2.7.2",
  "description": "Professional EXIF Frame Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "npm start",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "F.Z.R",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "exif-js": "^2.3.0",
    "exif-parser": "^0.1.12",
    "exiftool-vendored": "^33.5.0",
    "lucide": "^0.344.0",
    "system-font-families": "^1.0.0"
  },
  "build": {
    "appId": "com.rzframe.workstation",
    "win": {
      "target": [
        "nsis",
        "zip",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.ts",
      "!*.map",
      "!package-lock.json",
      "!*.log",
      "!log",
      "!startup_log.txt",
      "!RZFrame.vbs",
      "!start.bat",
      "!src/**/*.ts",
      "assets/ui/**/*",
      "!assets/logos/**/*"
    ],
    "extraFiles": [
      "assets/logos"
    ],
    "asarUnpack": [
      "**/node_modules/exiftool-vendored.exe/**/*",
      "**/node_modules/exiftool-vendored.pl/**/*",
      "**/node_modules/system-font-families/**/*",
      "**/node_modules/exiftool-vendored/**/*"
    ]
  }
}